<div class="container mt-5">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger fw-bold">Donation Appointments</h2>
  </div>


  <!-- Search + Filter -->
 <div class="row mb-4">

  <%= form_with url: request.path, method: :get, local: true do %>

   <div class="row mb-3">

  <div class="col-md-8">
    <input type="text"
           name="search"
           class="form-control"
           placeholder="Search by user name, mobile no or email"
           value="<%= params[:search] %>">
  </div>

  <div class="col-md-2">
    <button class="btn btn-danger w-100">
      Search
    </button>
  </div>

</div>

    <div class="col-md-3">
      <select name="status"
              class="form-select"
              onchange="this.form.submit()">

        <option value="">All Status</option>

        <option value="scheduled"
          <%= "selected" if params[:status] == "scheduled" %>>
          Scheduled
        </option>

        <option value="completed"
          <%= "selected" if params[:status] == "completed" %>>
          Completed
        </option>

      </select>
    </div>

  <% end %>

</div>


  <!-- Cards -->
   <% if @donation_appointments.present? %>
     <div class="row">

      <% @donation_appointments.each do |appointment| %>

        <div class="col-md-6 col-lg-4 mb-4">

          <div class="card shadow-sm border-0 h-100">

            <div class="card-body d-flex flex-column">

              <h5 class="card-title text-danger fw-bold">
                <%= appointment.blood_bank.name %>
              </h5>

              <p class="mb-1">
                <strong>User:</strong>
                <%= appointment.user.first_name %>
              </p>

              <p class="mb-1">
                <strong>Date:</strong>
                <%= appointment.scheduled_date %>
              </p>

              <p class="mb-1">
                <strong>Time:</strong>
                <%= appointment.scheduled_time_start.strftime("%I:%M %p") %>
                -
                <%= appointment.scheduled_time_end.strftime("%I:%M %p") %>
              </p>

              <p class="mb-3">
                <strong>Status:</strong>

                <% if appointment.status == "scheduled" %>
                  <span class="badge bg-warning text-dark">Scheduled</span>
                <% else %>
                  <span class="badge bg-secondary">Completed</span>
                <% end %>

              </p>

              <!-- Button -->
              <div class="mt-auto">
                <button
                  class="btn btn-outline-primary w-100"
                  data-bs-toggle="modal"
                  data-bs-target="#appointmentModal<%= appointment.id %>">
                  View Details
                </button>
              </div>

            </div>

          </div>
        </div>


      <!-- Modal -->
      <div class="modal fade"
           id="appointmentModal<%= appointment.id %>"
           tabindex="-1">

        <div class="modal-dialog modal-lg">

          <div class="modal-content">

            <div class="modal-header">
              <h5 class="modal-title">
                Appointment Details
              </h5>

              <button
                type="button"
                class="btn-close"
                data-bs-dismiss="modal">
              </button>
            </div>


            <div class="modal-body">

              <h6 class="text-danger fw-bold mb-3">
                User Information
              </h6>

              <p><strong>Name:</strong> <%= appointment.user.first_name %></p>
              <p><strong>Email:</strong> <%= appointment.user.email %></p>
              <p><strong>Blood Group:</strong> <%= appointment.user.blood_group %></p>



              <hr>


              <h6 class="text-danger fw-bold mb-3">
                Blood Bank Information
              </h6>

              <p><strong>Name:</strong> <%= appointment.blood_bank.name %></p>
              <p><strong>City:</strong> <%= appointment.blood_bank.city %></p>
              <p><strong>Phone:</strong> <%= appointment.blood_bank.phone_number %></p>



              <hr>


              <h6 class="text-danger fw-bold mb-3">
                Appointment Information
              </h6>

              <p><strong>Date:</strong> <%= appointment.scheduled_date %></p>

              <p>
                <strong>Time:</strong>
                <%= appointment.scheduled_time_start.strftime("%I:%M %p") %>
                -
                <%= appointment.scheduled_time_end.strftime("%I:%M %p") %>
              </p>

              <p><strong>Status:</strong> <%= appointment.status %></p>

            </div>


            <div class="modal-footer">
            
            
            <% if appointment.status != "completed" %>
               <%= button_to "Complete Appointment",
                  accept_blood_bank_donation_appointment_path(
                    id: appointment.id,
                    blood_bank_id: appointment.blood_bank.id,
                    blood_group: appointment.user.blood_group
                  ),
                  method: :patch,
                  class: "btn btn-success" %>
            <% end %>
            

              <button
                class="btn btn-secondary"
                data-bs-dismiss="modal">
                Close
              </button>

            </div>

          </div>

        </div>

      </div>


    <% end %>

  </div>

  <% else %>
    
        <div class="alert alert-info">
        No donation appointments found.
        </div>
    
     <% end %>
  

</div>