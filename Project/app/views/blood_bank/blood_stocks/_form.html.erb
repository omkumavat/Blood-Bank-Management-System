<%= form_with url: url, method: local_assigns.fetch(:method, :post), local: true do |f| %>

  <% if local_assigns[:stock]&.errors&.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% local_assigns[:stock].errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= label_tag "blood_stock[blood_group]", "Blood Group", class: "form-label fw-semibold" %>
    <%= select_tag "blood_stock[blood_group]",
        options_for_select(
          ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"],
          local_assigns[:stock]&.blood_group
        ),
        prompt: "Select Blood Group",
        class: "form-select",
        disabled: local_assigns.fetch(:method, :post) == :patch %>
  </div>

  <div class="mb-3">
    <%= label_tag "blood_stock[quantity]", "Quantity (Units)", class: "form-label fw-semibold" %>
    <%= number_field_tag "blood_stock[quantity]",
        local_assigns[:stock]&.quantity,
        class: "form-control",
        placeholder: "Enter number of units",
        min: 0,
        required: true %>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= submit_tag(
        local_assigns.fetch(:method, :post) == :patch ? "Update Stock" : "Add Stock",
        class: "btn btn-danger px-4"
    ) %>
    <%= link_to "Cancel", blood_bank_blood_stocks_path, class: "btn btn-outline-secondary px-4" %>
  </div>

<% end %>