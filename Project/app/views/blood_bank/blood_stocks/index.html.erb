<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger fw-bold mb-0">Manage Blood Stocks</h2>
  </div>

  <% if current_blood_bank.present? %>
    <div class="card border-0 shadow-sm mb-4" style="border-left: 4px solid #dc3545 !important;">
      <div class="card-body">
        <h5 class="text-danger fw-bold mb-1"><%= current_blood_bank.name %></h5>
        <p class="text-muted mb-1 small">📍 <%= current_blood_bank.city %>, <%= current_blood_bank.state %>, <%= current_blood_bank.country %></p>
        <p class="text-muted mb-0 small">📞 <%= current_blood_bank.phone_number %></p>
      </div>
    </div>

    <div class="mb-4">
      <%= link_to "+ Add Blood Stock",
          new_blood_bank_blood_stock_path,
          class: "btn btn-danger" %>
    </div>

    <% if @blood_stocks.present? %>
      <div class="row g-3">
        <% @blood_stocks.each do |stock| %>
          <%= render "shared/blood_stocks/stock_card",
              stock: stock,
              update_url: edit_blood_bank_blood_stock_path(stock) %>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-info">No blood stock available yet.</div>
    <% end %>
  <% end %>
</div>