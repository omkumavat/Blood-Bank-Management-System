<div class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger fw-bold">Blood Requests</h2>
  </div>

  <%# Filters %>
  <div class="row mb-4">
    <%= form_with url: request.path, method: :get, local: true do %>

      <div class="row mb-3">
        <div class="col-md-6">
          <input type="text" name="search" class="form-control"
                 placeholder="Search by hospital name"
                 value="<%= params[:search] %>">
        </div>
        <div class="col-md-2">
          <button class="btn btn-danger w-100">Search</button>
        </div>
      </div>

      <div class="row">
        <div class="col-md-3">
          <select name="blood_group" class="form-select" onchange="this.form.submit()">
            <option value="">All Blood Groups</option>
            <% ["A+","A-","B+","B-","O+","O-","AB+","AB-"].each do |group| %>
              <option value="<%= group %>" <%= "selected" if params[:blood_group] == group %>>
                <%= group %>
              </option>
            <% end %>
          </select>
        </div>

        <div class="col-md-3">
          <select name="quantity" class="form-select" onchange="this.form.submit()">
            <option value="">All Quantity</option>
            <option value="2"  <%= "selected" if params[:quantity] == "2" %>>More than 2</option>
            <option value="5"  <%= "selected" if params[:quantity] == "5" %>>More than 5</option>
            <option value="10" <%= "selected" if params[:quantity] == "10" %>>More than 10</option>
          </select>
        </div>
      </div>

    <% end %>
  </div>

  <%# Cards %>
  <% if @blood_requests.present? %>
    <div class="row">
      <% @blood_requests.each do |blood_request| %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex flex-column">

              <h5 class="card-title text-danger fw-bold">
                <%= blood_request.blood_group %> Blood Needed
              </h5>

              <p class="mb-1"><strong>Hospital:</strong> <%= blood_request.hospital.name %></p>
              <p class="mb-1"><strong>Blood Bank:</strong> <%= blood_request.blood_bank.name %></p>
              <p class="mb-1"><strong>Quantity:</strong> <%= blood_request.quantity %> Units</p>

              <p class="mb-3">
                <strong>Status:</strong>
                <% if blood_request.status == "pending" %>
                  <span class="badge bg-warning text-dark">Pending</span>
                <% else %>
                  <span class="badge bg-success">Completed</span>
                <% end %>
              </p>

              <div class="mt-auto">
                <%= link_to "View Details",
                    blood_bank_blood_request_path(blood_request),
                    class: "btn btn-outline-primary w-100" %>
              </div>

            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info">No blood requests found.</div>
  <% end %>

</div>