<div class="container-fluid mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger fw-bold">Blood Requests</h2>
    <%= link_to "Create Blood Request", new_hospital_blood_request_path, class: "btn btn-danger" %>
  </div>

  <%# Filter %>
  <div class="row mb-4">
    <%= form_with url: request.path, method: :get, local: true do %>
      <div class="col-md-3">
        <select name="status" class="form-select" onchange="this.form.submit()">
          <option value="">All Status</option>
          <option value="pending"   <%= "selected" if params[:status] == "pending" %>>Pending</option>
          <option value="fulfilled" <%= "selected" if params[:status] == "fulfilled" %>>Fulfilled</option>
        </select>
      </div>
    <% end %>
  </div>

  <% if @blood_requests.present? %>
    <div class="row">
      <% @blood_requests.each do |blood_request| %>

        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex flex-column">

              <h5 class="card-title text-danger fw-bold"><%= blood_request.blood_group %></h5>

              <% if blood_request.blood_bank&.id %>
                <p class="mb-1"><strong>Accepted by Blood Bank:</strong> <%= blood_request.blood_bank.name %></p>
              <% elsif blood_request.user&.id %>
                <p class="mb-1"><strong>Accepted by User:</strong> <%= blood_request.user.first_name %> <%= blood_request.user.last_name %></p>
              <% else %>
                <p class="mb-1"><strong>Accepted by:</strong> Not accepted yet</p>
              <% end %>

              <p class="mb-1"><strong>Quantity:</strong> <%= blood_request.quantity %></p>

              <p class="mb-3">
                <strong>Status:</strong>
                <% if blood_request.status == "pending" %>
                  <span class="badge bg-warning text-dark">Pending</span>
                <% else %>
                  <span class="badge bg-secondary">Fulfilled</span>
                <% end %>
              </p>

              <div class="mt-auto">
                <%= link_to "View Details", hospital_blood_request_path(blood_request), class: "btn btn-outline-primary w-100" %>
              </div>

            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info">No blood requests found.</div>
  <% end %>

</div>