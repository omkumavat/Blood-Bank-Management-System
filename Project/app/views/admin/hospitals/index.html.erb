<div class="container mt-5">

  <!-- Header + Filter -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-danger">Hospitals</h2>

    <%= form_with url: request.path, method: :get, local: true do %>
      <select name="status" class="form-select" onchange="this.form.submit()" style="width:200px;">
        <option value="all">All</option>
        <option value="pending" <%= "selected" if params[:status] == "pending" %>>
          Pending
        </option>
        <option value="verified" <%= "selected" if params[:status] == "verified" %>>
          Verified
        </option>
      </select>
    <% end %>
  </div>


  <% if @hospitals.present? %>

    <div class="row">

      <% @hospitals.each do |hospital| %>

        <div class="col-md-6 col-lg-4 mb-4">

          <div class="card shadow-sm border-0 h-100">

            <div class="card-body d-flex flex-column">

              <h5 class="card-title text-danger fw-bold">
                <%= hospital.name %>
              </h5>

              <p class="mb-1">
                <strong>City:</strong> <%= hospital.city %>
              </p>

              <p class="mb-1">
                <strong>State:</strong> <%= hospital.state %>
              </p>

              <p class="mb-1">
                <strong>Phone:</strong> <%= hospital.phone_number %>
              </p>

              <p class="mb-3">
                <strong>Status:</strong>

                <% if hospital.verified == true %>
                  <span class="badge bg-success">Verified</span>
                <% else %>
                  <span class="badge bg-warning text-dark">Pending</span>
                <% end %>

              </p>

              <!-- Buttons -->
              <div class="mt-auto d-flex gap-2">

               
                <% if hospital.verified == false %>
                  <%# <%= link_to "Verify",
                        verify_admin_blood_bank_path(bank),
                        method: :patch,
                        class: "btn btn-success w-100" %> 
                    <button
              class="btn btn-danger"
              data-bs-toggle="modal"
              data-bs-target="#hospitalModal<%= hospital.id %>">
              Verify
            </button>

                  <div class="modal fade"
           id="hospitalModal<%= hospital.id %>"
           tabindex="-1">

        <div class="modal-dialog">

          <div class="modal-content">

            <div class="modal-header">
              <h5 class="modal-title">
                <%= hospital.name %>
              </h5>

              <button type="button"
                      class="btn-close"
                      data-bs-dismiss="modal">
              </button>
            </div>

            <div class="modal-body">

              <p><strong>City:</strong> <%= hospital.city %></p>

              <p><strong>State:</strong> <%= hospital.state %></p>

              <p><strong>Phone:</strong> <%= hospital.phone_number %></p>

              <p><strong>Address:</strong> <%= hospital.address %></p>

              <p><strong>Status:</strong> <%= hospital.verified ? "Verified" : "Pending" %></p>

            </div>

            <div class="modal-footer">
            <%= button_to "Verify",
                  verify_admin_hospital(hospital),
                  method: :patch,
                  class: "btn btn-success" %>
                  
              <button class="btn btn-secondary"
                      data-bs-dismiss="modal">
                Close
              </button>

            </div>

          </div>

        </div>

      </div>

                <% end %>

              </div>

            </div>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <div class="alert alert-warning">
      No hospitals found.
    </div>

  <% end %>

</div>