<div class="container mt-5">
   <h2 class="text-danger mb-4">Create Blood Request</h2>
   <div class="card shadow p-4">
      <%= form_with url: create_blood_request_path, method: :post, scope: :blood_request, local: true do |f| %>
      <div class="mb-3">
         <%= f.label :blood_group %>
         <%= f.select :blood_group,
            ["A+","A-","B+","B-","AB+","AB-","O+","O-"],
            {},
            class: "form-select" %>
      </div>
      <div class="mb-3">
         <%= f.label :quantity %>
         <%= f.number_field :quantity,
            class: "form-control",
            placeholder: "Enter quantity" %>
      </div>
      <div class="mb-3">
         <label class="form-label">
         Allow Users To Respond?
         </label>
         <div class="form-check">
            <%= f.radio_button :allowed_to_users, true,
               class: "form-check-input" %>
            <%= f.label :allowed_to_users_true,
               "Yes",
               class: "form-check-label" %>
         </div>
         <div class="form-check">
            <%= f.radio_button :allowed_to_users, false,
               class: "form-check-input" %>
            <%= f.label :allowed_to_users_false,
               "No",
               class: "form-check-label" %>
         </div>
      </div>
      <%= f.hidden_field :blood_bank_id,
         value: current_hospital.id %>
      <div class="mt-4">
         <%= f.submit "Create Request",
            class: "btn btn-danger" %>
         <%= link_to "Back",
            hospital_blood_requests_path,
            class: "btn btn-secondary ms-2" %>
      </div>
      <% end %>
   </div>
</div>