<h2 class="mb-4">Welcome, <%= current_user.first_name %> 👋</h2>

<div class="card shadow">
  <div class="card-body">

    <h5 class="card-title">Profile Information</h5>
    <hr>

    <p><strong>Full Name:</strong> <%= current_user.first_name %> <%= current_user.last_name %></p>
    <p><strong>Email:</strong> <%= current_user.email %></p>
    <p><strong>Phone:</strong> <%= current_user.phone_number %></p>
    <p><strong>Blood Group:</strong> <%= current_user.blood_group %></p>
    <p><strong>Location:</strong> <%= current_user.city %>, <%= current_user.state %></p>
    <p><strong>Date of Birth:</strong> <%= current_user.date_of_birth %></p>

  </div>
</div>

<div class="container mt-5">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold">Nearby Blood Requests</h2>
      <p class="text-muted mb-0">
        Requests near <strong><%= current_user.city %></strong>
      </p>
    </div>
  </div>

  <% if @blood_requests.present? %>

    <div class="row">

      <% @blood_requests.each do |request| %>

        <div class="col-md-6 col-lg-4 mb-4">

          <div class="card h-100 shadow-sm border-0">

            <div class="card-body d-flex flex-column">

              <h5 class="card-title text-danger fw-bold">
                <%= request.blood_group %> Blood Required
              </h5>

              <p class="mb-1">
                <strong>Hospital:</strong> <%= request.hospital.name %>
              </p>

              <p class="mb-1">
                <strong>City:</strong> <%= request.hospital.city %>
              </p>

              <p class="mb-3">
                <strong>Units Required:</strong> <%= request.quantity %>
              </p>

              <div class="mt-auto">

                <button
                  class="btn btn-danger w-100"
                  data-bs-toggle="modal"
                  data-bs-target="#requestModal<%= request.id %>">
                  View Request
                </button>

              </div>

            </div>

          </div>

        </div>

        <!-- Modal -->
        <div class="modal fade"
             id="requestModal<%= request.id %>"
             tabindex="-1">

          <div class="modal-dialog modal-lg">

            <div class="modal-content">

              <div class="modal-header">
                <h5 class="modal-title">
                  Blood Request Details
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
              </div>

              <div class="modal-body">

                <h6 class="text-danger fw-bold mb-3">
                  Blood Request Information
                </h6>

                <p><strong>Blood Group:</strong> <%= request.blood_group %></p>
                <p><strong>Units Required:</strong> <%= request.quantity %></p>

                <hr>

                <h6 class="text-danger fw-bold mb-3">
                  Hospital Information
                </h6>

                <p><strong>Name:</strong> <%= request.hospital.name %></p>
                <p><strong>Phone:</strong> <%= request.hospital.phone_number %></p>
                <p><strong>City:</strong> <%= request.hospital.city %></p>
                <p><strong>State:</strong> <%= request.hospital.state %></p>
                <p><strong>Country:</strong> <%= request.hospital.country %></p>
                <p><strong>Address:</strong> <%= request.hospital.address %></p>

              </div>

              <div class="modal-footer">

                <%= button_to "Accept Request",
                      user_accept_blood_request_path(request.id),
                      method: :post,
                      class: "btn btn-success" %>

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                  Close
                </button>

              </div>

            </div>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <div class="alert alert-warning">
      No blood requests found near you.
    </div>

  <% end %>

</div>