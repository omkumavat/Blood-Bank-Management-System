<div class="container mt-5">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold">Accepted Blood Requests</h2>
      <p class="text-muted mb-0">
        Requests you have accepted
      </p>
    </div>
  </div>

  <% if @accepted_requests.present? %>

    <div class="row">

      <% @accepted_requests.each do |request| %>

        <div class="col-md-6 col-lg-4 mb-4">

          <div class="card h-100 shadow-sm border-0">

            <div class="card-body d-flex flex-column">

              <h5 class="card-title text-success fw-bold">
                <%= request.blood_group %> Blood Donation
              </h5>

              <p class="mb-1">
                <strong>Hospital:</strong> <%= request.hospital.name %>
              </p>

              <p class="mb-1">
                <strong>City:</strong> <%= request.hospital.city %>
              </p>

              <p class="mb-1">
                <strong>Units:</strong> <%= request.quantity %>
              </p>

              <span class="badge bg-success mb-3">
                Accepted
              </span>

              <div class="mt-auto">

                <button
                  class="btn btn-success w-100"
                  data-bs-toggle="modal"
                  data-bs-target="#acceptedModal<%= request.id %>">
                  View Details
                </button>

              </div>

            </div>

          </div>

        </div>

        <!-- Modal -->
        <div class="modal fade"
             id="acceptedModal<%= request.id %>"
             tabindex="-1">

          <div class="modal-dialog modal-lg">

            <div class="modal-content">

              <div class="modal-header">
                <h5 class="modal-title">
                  Accepted Request Details
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal">
                </button>
              </div>

              <div class="modal-body">

                <!-- Request Info -->
                <h6 class="text-danger fw-bold mb-3">
                  Blood Request Information
                </h6>

                <p><strong>Blood Group:</strong> <%= request.blood_group %></p>
                <p><strong>Units Required:</strong> <%= request.quantity %></p>
                <p><strong>Required By Hospital:</strong> <%= request.hospital.name %></p>
                <p><strong>Requested In:</strong> <%= DateTime.parse(request.created_at.to_s).strftime('%B %d, %Y') %></p>
                <p><strong>Accepted In:</strong> <%= DateTime.parse(request.updated_at.to_s).strftime('%B %d, %Y') %></p>
                <hr>

                <!-- Hospital Info -->
                <h6 class="text-danger fw-bold mb-3">
                  Hospital Information
                </h6>

                <p><strong>Name:</strong> <%= request.hospital.name %></p>
                <p><strong>Phone:</strong> <%= request.hospital.phone_number %></p>
                <p><strong>City:</strong> <%= request.hospital.city %></p>
                <p><strong>Address:</strong> <%= request.hospital.address %></p>

                <hr>

                <!-- Donor Info -->
                <h6 class="text-danger fw-bold mb-3">
                  Donor Information
                </h6>

                <p>
                  <strong>Name:</strong>
                  <%= current_user.first_name %> <%= current_user.last_name %>
                </p>

                <p>
                  <strong>Email:</strong>
                  <%= current_user.email %>
                </p>

                <p>
                  <strong>Phone:</strong>
                  <%= current_user.phone_number %>
                </p>

                <p>
                  <strong>Blood Group:</strong>
                  <%= current_user.blood_group %>
                </p>

                <p>
                  <strong>City:</strong>
                  <%= current_user.city %>
                </p>

                <p>
                  <strong>Address:</strong>
                  <%= current_user.address %>
                </p>

              </div>

              <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                  Close
                </button>

              </div>

            </div>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <div class="alert alert-warning">
      You have not accepted any blood requests yet.
    </div>

  <% end %>

</div>