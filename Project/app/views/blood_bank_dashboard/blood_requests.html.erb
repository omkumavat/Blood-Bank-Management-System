<div class="container mt-5">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger fw-bold">Blood Requests</h2>
  </div>


  <!-- Search + Filters -->
  <div class="row mb-4">

    <%= form_with url: request.path, method: :get, local: true do %>

      <div class="row mb-3">

        <div class="col-md-6">
          <input type="text"
                 name="search"
                 class="form-control"
                 placeholder="Search by hospital name"
                 value="<%= params[:search] %>">
        </div>

        <div class="col-md-2">
          <button class="btn btn-danger w-100">
            Search
          </button>
        </div>

      </div>


      <div class="row">

        <!-- Blood Group Filter -->
        <div class="col-md-3">
          <select name="blood_group"
                  class="form-select"
                  onchange="this.form.submit()">

            <option value="">All Blood Groups</option>

            <% ["A+","A-","B+","B-","O+","O-","AB+","AB-"].each do |group| %>

              <option value="<%= group %>"
                <%= "selected" if params[:blood_group] == group %>>

                <%= group %>

              </option>

            <% end %>

          </select>
        </div>


        <!-- Quantity Filter -->
        <div class="col-md-3">
          <select name="quantity"
                  class="form-select"
                  onchange="this.form.submit()">

            <option value="">All Quantity</option>

            <option value="2"
              <%= "selected" if params[:quantity] == "2" %>>
              More than 2
            </option>

            <option value="5"
              <%= "selected" if params[:quantity] == "5" %>>
              More than 5
            </option>

            <option value="10"
              <%= "selected" if params[:quantity] == "10" %>>
              More than 10
            </option>

          </select>
        </div>

      </div>

    <% end %>

  </div>


  <!-- Cards -->
  <% if @blood_requests.present? %>

    <div class="row">

      <% @blood_requests.each do |request| %>

        <div class="col-md-6 col-lg-4 mb-4">

          <div class="card shadow-sm border-0 h-100">

            <div class="card-body d-flex flex-column">

              <h5 class="card-title text-danger fw-bold">
                <%= request.blood_group %> Blood Needed
              </h5>


              <p class="mb-1">
                <strong>Hospital:</strong>
                <%= request.hospital.name %>
              </p>

              <p class="mb-1">
                <strong>Blood Bank:</strong>
                <%= request.blood_bank.name %>
              </p>

              <p class="mb-1">
                <strong>Quantity:</strong>
                <%= request.quantity %> Units
              </p>


              <p class="mb-3">
                <strong>Status:</strong>

                <% if request.status == "pending" %>
                  <span class="badge bg-warning text-dark">Pending</span>
                <% else %>
                  <span class="badge bg-success">Completed</span>
                <% end %>

              </p>


              <!-- Button -->
              <div class="mt-auto">

                <button
                  class="btn btn-outline-primary w-100"
                  data-bs-toggle="modal"
                  data-bs-target="#requestModal<%= request.id %>">

                  View Details

                </button>

              </div>

            </div>

          </div>

        </div>



        <!-- Modal -->
        <div class="modal fade"
             id="requestModal<%= request.id %>"
             tabindex="-1">

          <div class="modal-dialog modal-lg">

            <div class="modal-content">

              <div class="modal-header">

                <h5 class="modal-title">
                  Blood Request Details
                </h5>

                <button
                  type="button"
                  class="btn-close"
                  data-bs-dismiss="modal">
                </button>

              </div>


              <div class="modal-body">

                <h6 class="text-danger fw-bold mb-3">
                  Hospital Information
                </h6>

                <p><strong>Name:</strong> <%= request.hospital.name %></p>
                <p><strong>City:</strong> <%= request.hospital.city %></p>
                <p><strong>Email:</strong> <%= request.hospital.email %></p>


                <hr>


                <h6 class="text-danger fw-bold mb-3">
                  Blood Bank Information
                </h6>

                <p><strong>Name:</strong> <%= request.blood_bank.name %></p>
                <p><strong>City:</strong> <%= request.blood_bank.city %></p>
                <p><strong>Phone:</strong> <%= request.blood_bank.phone_number %></p>


                <hr>


                <h6 class="text-danger fw-bold mb-3">
                  Request Information
                </h6>

                <p><strong>Blood Group:</strong> <%= request.blood_group %></p>

                <p><strong>Quantity:</strong> <%= request.quantity %> Units</p>

                <p><strong>Status:</strong> <%= request.status %></p>

              </div>


              <div class="modal-footer">

                <button
                  class="btn btn-secondary"
                  data-bs-dismiss="modal">

                  Close

                </button>

              </div>

            </div>

          </div>

        </div>


      <% end %>

    </div>

  <% else %>

    <div class="alert alert-info">
      No blood requests found.
    </div>

  <% end %>

</div>