<section class="bg-danger text-white text-center py-5">

  <div class="container">

    <h1 class="display-4 fw-bold">
      Save Lives with Blood Donation
    </h1>

    <p class="lead">
      Connecting donors, hospitals, and blood banks in one platform
    </p>

    <%= link_to "Become a Donor",
          new_user_registration_path,
          class: "btn btn-light btn-lg mt-3" %>

  </div>

</section>

<section class="py-5">

  <div class="container">

    <div class="row align-items-center">

      <div class="col-md-6">

        <h2 class="fw-bold">Why Blood Donation Matters</h2>

        <p>
          Every year millions of people require blood transfusions during
          surgeries, accidents, and medical treatments. A single blood
          donation can save up to three lives.
        </p>

        <p>
          Our platform connects donors with hospitals and blood banks
          quickly during emergencies.
        </p>

      </div>

      <div class="col-md-6">

        <img src="https://images.unsplash.com/photo-1615461065922-b73b01f84dbb"
             class="img-fluid rounded shadow">

      </div>

    </div>

  </div>

</section>

<section class="bg-light py-5">

  <div class="container text-center">

    <h2 class="fw-bold mb-4">Platform Features</h2>

    <div class="row">

      <div class="col-md-4">

        <div class="card shadow border-0">

          <div class="card-body">

            <h5 class="text-danger">Find Blood Quickly</h5>

            <p>
              Search nearby blood banks and hospitals instantly
              during emergencies.
            </p>

          </div>

        </div>

      </div>

      <div class="col-md-4">

        <div class="card shadow border-0">

          <div class="card-body">

            <h5 class="text-danger">Donate Easily</h5>

            <p>
              Register as a donor and respond to urgent blood
              requests from hospitals.
            </p>

          </div>

        </div>

      </div>

      <div class="col-md-4">

        <div class="card shadow border-0">

          <div class="card-body">

            <h5 class="text-danger">Real-Time Requests</h5>

            <p>
              Hospitals can instantly create blood requests and
              notify nearby donors.
            </p>

          </div>

        </div>

      </div>

    </div>

  </div>

</section>

<section class="py-5 text-center">

  <div class="container">

    <h2 class="fw-bold mb-4">Impact We Create</h2>

    <div class="row">

      <div class="col-md-3">
        <h1 class="text-danger">500+</h1>
        <p>Registered Donors</p>
      </div>

      <div class="col-md-3">
        <h1 class="text-danger">120+</h1>
        <p>Hospitals</p>
      </div>

      <div class="col-md-3">
        <h1 class="text-danger">80+</h1>
        <p>Blood Banks</p>
      </div>

      <div class="col-md-3">
        <h1 class="text-danger">2000+</h1>
        <p>Lives Saved</p>
      </div>

    </div>

  </div>

</section>


<section class="bg-danger text-white text-center py-5 ">

  <div class="container">

    <h2 class="fw-bold">
      Become a Hero Today
    </h2>

    <p>
      Your blood can give someone another chance at life.
    </p>

    <%= link_to "Register as Donor",
          new_user_registration_path,
          class: "btn btn-light btn-lg" %>

  </div>

</section>