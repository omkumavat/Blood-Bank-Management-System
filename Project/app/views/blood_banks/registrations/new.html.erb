<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">

      <div class="card shadow-lg border-0">
        <div class="card-body p-4">

          <h2 class="text-center mb-4">Blood Bank Registration</h2>

          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

            <%= render "blood_banks/shared/error_messages", resource: resource %>

            <!-- Name -->
            <div class="mb-3">
              <%= f.label :name, class: "form-label" %>
              <%= f.text_field :name, class: "form-control", required: true %>
            </div>

            <!-- Email -->
            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email, class: "form-control", autofocus: true, required: true %>
            </div>

            <!-- Phone -->
            <div class="mb-3">
              <%= f.label :phone_number, class: "form-label" %>
              <%= f.text_field :phone_number, class: "form-control", required: true %>
            </div>

            <!-- Website -->


            <!-- Address -->
            <div class="mb-3">
              <%= f.label :address, class: "form-label" %>
              <%= f.text_area :address, class: "form-control", rows: 2, required: true %>
            </div>

            <!-- Country / State / City -->
            <div class="row">
              <div class="col-md-4 mb-3">
                <%= f.label :country, class: "form-label" %>
                <%= f.text_field :country, class: "form-control", required: true %>
              </div>

              <div class="col-md-4 mb-3">
                <%= f.label :state, class: "form-label" %>
                <%= f.text_field :state, class: "form-control", required: true %>
              </div>

              <div class="col-md-4 mb-3">
                <%= f.label :city, class: "form-label" %>
                <%= f.text_field :city, class: "form-control", required: true %>
              </div>
            </div>

            <!-- Pincode -->
            <div class="mb-3">
              <%= f.label :pincode, class: "form-label" %>
              <%= f.text_field :pincode, class: "form-control", required: true %>
            </div>

            <!-- Hospital Selection -->
           

            <hr>

            <!-- Password -->
            <div class="mb-3">
              <%= f.label :password, class: "form-label" %>
              <% if @minimum_password_length %>
                <div class="form-text">
                  Minimum <%= @minimum_password_length %> characters
                </div>
              <% end %>
              <%= f.password_field :password, class: "form-control", required: true %>
            </div>

            <!-- Password Confirmation -->
            <div class="mb-3">
              <%= f.label :password_confirmation, class: "form-label" %>
              <%= f.password_field :password_confirmation, class: "form-control", required: true %>
            </div>

            <!-- Submit -->
            <div class="d-grid">
              <%= f.submit "Register Blood Bank", class: "btn btn-danger btn-lg" %>
            </div>

          <% end %>

          <div class="text-center mt-3">
            <%= render "blood_banks/shared/links" %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>