<div class="container mt-5" style="max-width: 500px;">
  <div class="w-100 mb-3">
    <%= link_to "← Back to Home", home_path, class: "btn btn-outline-secondary" %>
  </div>

  <div class="card shadow border-0">
    <div class="card-body">

      <h3 class="text-center text-danger mb-4">
        Admin Sign Up
      </h3>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

        <%= render "admins/shared/error_messages", resource: resource %>

        <!-- Name -->
        <div class="mb-3">
          <%= f.label :name, class: "form-label fw-bold" %>
          <%= f.text_field :name, class: "form-control", placeholder: "Enter full name" %>
        </div>

        <!-- Role -->
        <div class="mb-3">
          <%= f.label :role, class: "form-label fw-bold" %>
          <%= f.select :role,
              [["Super Admin", "superadmin"], ["Blood Bank Admin", "bb_admin"], ["Hospital Admin", "hospital_admin"]],
              {},
              class: "form-select" %>
        </div>

        <!-- Email -->
        <div class="mb-3">
          <%= f.label :email, class: "form-label fw-bold" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "form-control",
              placeholder: "Enter email" %>
        </div>

        <!-- Password -->
        <div class="mb-3">
          <%= f.label :password, class: "form-label fw-bold" %>

          <% if @minimum_password_length %>
            <small class="text-muted">
              (<%= @minimum_password_length %> characters minimum)
            </small>
          <% end %>

          <%= f.password_field :password,
              autocomplete: "new-password",
              class: "form-control",
              placeholder: "Enter password" %>
        </div>

        <!-- Password Confirmation -->
        <div class="mb-3">
          <%= f.label :password_confirmation, class: "form-label fw-bold" %>
          <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "form-control",
              placeholder: "Confirm password" %>
        </div>

        <!-- Submit -->
        <div class="d-grid">
          <%= f.submit "Create Admin",
              class: "btn btn-danger btn-lg" %>
        </div>

      <% end %>

      <div class="text-center mt-3">
        <%= render "admins/shared/links" %>
      </div>

    </div>
  </div>

</div>