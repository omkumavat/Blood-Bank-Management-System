<div class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold">Accepted Blood Requests</h2>
      <p class="text-muted mb-0">Requests you have accepted</p>
    </div>
  </div>

  <% if @blood_requests.present? %>
    <div class="row">
      <% @blood_requests.each do |blood_request| %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card h-100 shadow-sm border-0">
            <div class="card-body d-flex flex-column">

              <h5 class="card-title text-success fw-bold">
                <%= blood_request.blood_group %> Blood Donation
              </h5>
              <p class="mb-1"><strong>Hospital:</strong> <%= blood_request.hospital.name %></p>
              <p class="mb-1"><strong>City:</strong>     <%= blood_request.hospital.city %></p>
              <p class="mb-1"><strong>Units:</strong>    <%= blood_request.quantity %></p>
              <span class="badge bg-success mb-3">Accepted</span>

              <div class="mt-auto">
                <%= link_to "View Details",
                    user_blood_request_path(blood_request),
                    class: "btn btn-success w-100" %>
              </div>

            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-warning">You have not accepted any blood requests yet.</div>
  <% end %>

</div>