<div class="container mt-5">

  <!-- Page Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">

    <h2 class="fw-bold text-danger">
      My Donation Appointments
    </h2>

    <!-- Sorting Dropdown -->
    <%= form_with url: user_donation_appointments_path, method: :get, local: true do %>

      <select name="sort" class="form-select" onchange="this.form.submit()">

        <option value="">Sort By</option>

        <option value="latest" <%= "selected" if params[:sort] == "latest" %>>
          Latest
        </option>

        <option value="oldest" <%= "selected" if params[:sort] == "oldest" %>>
          Oldest
        </option>

        <option value="upcoming" <%= "selected" if params[:sort] == "upcoming" %>>
          Upcoming
        </option>

        <option value="past" <%= "selected" if params[:sort] == "past" %>>
          Past
        </option>

      </select>

    <% end %>

  </div>


  <% if @donation_appointments.present? %>

    <div class="row">

      <% @donation_appointments.each do |appointment| %>

        <div class="col-md-6 col-lg-4 mb-4">

          <div class="card shadow-sm border-0 h-100">

            <div class="card-body d-flex flex-column">

              <h5 class="card-title text-danger fw-bold">
                <%= appointment.blood_bank.name %>
              </h5>

              <p class="mb-1">
                <strong>Date:</strong>
                <%= appointment.scheduled_date.strftime("%d %B %Y") %>
              </p>

              <p class="mb-1">
                <strong>Time:</strong>
                <%= appointment.scheduled_time_start.strftime("%I:%M %p") %>
                -
                <%= appointment.scheduled_time_end.strftime("%I:%M %p") %>
              </p>

              <p class="mb-1">
                <strong>City:</strong>
                <%= appointment.blood_bank.city %>
              </p>

              <p class="mb-3">
                <strong>Status:</strong>

                <% if appointment.status == "scheduled" %>
                  <span class="badge bg-warning text-dark">Scheduled</span>

                <% elsif appointment.status == "completed" %>
                  <span class="badge bg-success">Completed</span>

                <% end %>

              </p>

            </div>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <div class="alert alert-warning">
      No donation appointments found.
    </div>

  <% end %>

</div>