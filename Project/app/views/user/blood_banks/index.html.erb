<div class="container mt-5">

  <!-- Page Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold">Available Blood Banks</h2>
      <p class="text-muted mb-0">
        Showing results for <strong><%= current_user.city %></strong>
      </p>
    </div>
  </div>

  <% if @blood_banks.present? %>

    <div class="row">

      <% @blood_banks.each do |bank| %>
        <div class="col-md-6 col-lg-4 mb-4">

          <div class="card h-100 shadow-sm border-0">

            <div class="card-body d-flex flex-column">

              <h5 class="card-title text-danger fw-bold">
                <%= bank.name %>
              </h5>

              <p class="mb-1">
                <strong>City:</strong> <%= bank.city %>
              </p>

              <p class="mb-1">
                <strong>State:</strong> <%= bank.state %>
              </p>

              <p class="mb-1">
                <strong>Phone:</strong> <%= bank.phone_number %>
              </p>

              <p class="mb-3">
                <strong>Address:</strong> <%= bank.address %>
              </p>

              <!-- Push button to bottom -->
              <div class="mt-auto">

                <%= link_to "Donate Blood",
                      new_user_donation_appointment_path(blood_bank_id: bank.id),
                      class: "btn btn-danger w-100" %>

              </div>

            </div>

          </div>

        </div>
      <% end %>

    </div>

  <% else %>

    <div class="alert alert-warning">
      No blood banks found in your city.
    </div>

  <% end %>

</div>